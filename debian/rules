#!/usr/bin/make -f

# 屏蔽 aws_lc_rs 警告（修复之前的警告）
export RUSTFLAGS := -A unexpected-cfgs

# 原生 dh 规则，无任何插件
%:
	dh $@

# ===================== 核心修复：删除损坏的 Cargo.lock + 纯 Stage-1 构建 =====================
override_dh_auto_build:
	# 1. 删除冲突的锁文件（彻底解决 zlib-rs 校验和错误）
	rm -f Cargo.lock
	rm -f rustls/Cargo.lock
	
	# 2. 强制离线构建 + 无锁文件校验（OBS/chroot 专用）
	cargo build --release \
		--lib \
		--no-default-features \
		--features "ring,std,tls12"

# ===================== 跳过测试/示例（解决类型错误） =====================
override_dh_auto_test:
	@echo "Skipping tests/examples for OBS build"

# ===================== 标准安装 + 清理 =====================
override_dh_auto_install:
	dh_auto_install

override_dh_auto_clean:
	dh_auto_clean
	rm -rf target/
	rm -f Cargo.lock rustls/Cargo.lock