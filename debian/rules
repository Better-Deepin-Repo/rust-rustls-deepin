#!/usr/bin/make -f
# 屏蔽编译警告（保留你的原有配置）
export RUSTFLAGS := -A unexpected-cfgs

# 标准 Debian 构建规则（无需修改）
%:
	dh $@ --buildsystem=rust

# 修复核心：仅构建主包，跳过测试子包（彻底解决 regex 依赖报错）
override_dh_auto_build:
	cargo build --release \
		--lib \
		--offline \
		--no-default-features \
		--features "ring,std,tls12" \
		--package rustls  # 关键：只构建主包，跳过 connect-tests 子包

# 跳过测试（原有逻辑）
override_dh_auto_test:
	@echo "Skipping tests/examples for OBS build"

# 标准安装（原有逻辑）
override_dh_auto_install:
	dh_auto_install

# 清理（原有逻辑）
override_dh_auto_clean:
	dh_auto_clean
	rm -rf target/
	rm -f Cargo.lock rustls/Cargo.lock