#!/usr/bin/make -f
export RUSTFLAGS := -A unexpected-cfgs

# 核心：标准 dh-rust 构建，自动使用系统离线依赖
%:
	dh $@ --buildsystem=rust

# 关键：只传递构建参数，不手动执行 cargo！让 dh-rust 自动构建
override_dh_auto_build:
	dh_auto_build -- \
		--release \
		--lib \
		--no-default-features \
		--features="ring,std,tls12"

# 跳过测试
override_dh_auto_test:
	@echo "Skipping tests for OBS build"

# 标准清理
override_dh_auto_clean:
	dh_auto_clean
	rm -rf target/
	rm -f Cargo.lock