#!/usr/bin/make -f

# 全局屏蔽无用警告 (解决 aws_lc_rs 报错)
export RUSTFLAGS := -A unexpected-cfgs

# 标准Debian辅助工具入口
%:
	dh $@ --with rustc

# ===================== 纯 Stage-1 构建 (核心) =====================
# 只编译 rustls 核心库, 禁用native-certs, 无循环依赖
override_dh_auto_build:
	cargo build --release \
		--lib \
		--no-default-features \
		--features "ring,std,tls12"

# ===================== 跳过所有测试/示例 (彻底解决类型错误) =====================
override_dh_auto_test:
	@echo "Skipping all tests/examples (OBS chroot + native-certs 0.6 compatibility)"

# ===================== 跳过无用文件 (减小包体积) =====================
override_dh_auto_install:
	dh_auto_install -- --no-upstream-doc

# 清理构建残留
execute_after_dh_auto_clean:
	rm -rf target/
	rm -f rustls/sslkeylogfile.txt