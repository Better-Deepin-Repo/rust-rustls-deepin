     use alloc::sync::Arc;
     use alloc::vec::Vec;
@@ -144,7 +144,7 @@
     }
 }
 
-#[cfg(any(feature = "std", feature = "hashbrown"))]
+#[cfg(any(feature = "std", all(feature = "default", feature = "hashbrown")))]
